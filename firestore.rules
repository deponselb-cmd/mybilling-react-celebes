rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Customer Rules
    match /customers/{customerId} {
      function isValidCustomer(data) {
        return data.keys().hasAll(['id', 'name', 'phone', 'plan', 'status', 'address']) &&
               data.id is string &&
               data.name is string && data.name.size() <= 100 &&
               data.phone is string && data.phone.size() <= 20 &&
               data.plan is string &&
               data.status in ['active', 'isolated', 'pending'] &&
               data.address is string && data.address.size() <= 500;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCustomer(incoming()) && isValidId(customerId);
      allow update: if isSignedIn() && isValidCustomer(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'invoiceStatus', 'plan', 'address', 'phone', 'name', 'lat', 'lng', 'invoiceAmount'])
      );
      allow delete: if isSignedIn(); // In production, limit to Admins
    }

    // Staff Rules
    match /staff/{staffId} {
      function isValidStaff(data) {
        return data.keys().hasAll(['id', 'name', 'email', 'role', 'status']) &&
               data.id is string &&
               data.name is string &&
               data.email is string &&
               data.role in ['Super Admin', 'Technician', 'Support', 'Viewer'] &&
               data.status in ['active', 'inactive'];
      }

      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidStaff(incoming()) && isValidId(staffId);
    }

    // Inventory Rules
    match /inventory/{itemId} {
      function isValidItem(data) {
        return data.keys().hasAll(['id', 'itemName', 'sku', 'quantity', 'unitPrice']) &&
               data.itemName is string &&
               data.sku is string &&
               data.quantity is number &&
               data.unitPrice is number;
      }

      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidItem(incoming()) && isValidId(itemId);
    }

    // Sales Rules
    match /sales/{saleId} {
      function isValidSale(data) {
        return data.keys().hasAll(['id', 'saleId', 'total', 'method']) &&
               data.total is number &&
               data.method in ['cash', 'card', 'qris'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidSale(incoming()) && isValidId(saleId);
    }
  }
}
